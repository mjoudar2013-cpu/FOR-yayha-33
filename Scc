body {
  background: black;
  color: white;
}
* {      margin: 0;      padding: 0;      box-sizing: border-box;    }    html, body {      height: 100%;      background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 50%, #2d1b4e 100%);      font-family: 'Outfit', sans-serif;      color: #e0e0e0;    }    .app-wrapper {      width: 100%;      height: 100%;      display: flex;      flex-direction: column;      overflow-y: auto;      background:         repeating-linear-gradient(          0deg,          rgba(139, 69, 19, 0.02) 0px,          rgba(139, 69, 19, 0.02) 1px,          transparent 1px,          transparent 2px        ),        linear-gradient(135deg, #0a0e27 0%, #1a1f3a 50%, #2d1b4e 100%);    }    .header-section {      text-align: center;      padding: 60px 20px 40px;      background: radial-gradient(ellipse at center, rgba(45, 27, 78, 0.6) 0%, transparent 70%);      border-bottom: 2px solid rgba(200, 100, 150, 0.3);      position: relative;      overflow: hidden;    }    .header-section::before {      content: '';      position: absolute;      top: 0;      left: 0;      right: 0;      bottom: 0;      background:         radial-gradient(circle at 20% 50%, rgba(139, 69, 19, 0.1) 0%, transparent 50%),        radial-gradient(circle at 80% 80%, rgba(200, 100, 150, 0.05) 0%, transparent 50%);      pointer-events: none;    }    .header-content {      position: relative;      z-index: 1;    }    .title-main {      font-family: 'Cinzel', serif;      font-size: 3.5rem;      font-weight: 900;      margin-bottom: 10px;      background: linear-gradient(135deg, #ff6b9d 0%, #c44569 50%, #8b4513 100%);      -webkit-background-clip: text;      -webkit-text-fill-color: transparent;      background-clip: text;      text-transform: uppercase;      letter-spacing: 3px;      text-shadow: 0 0 30px rgba(200, 100, 150, 0.3);    }    .subtitle {      font-size: 1.2rem;      color: #b8a0d0;      margin-bottom: 20px;      font-weight: 300;      letter-spacing: 2px;    }    .age-badge {      display: inline-block;      font-family: 'Cinzel', serif;      font-size: 4rem;      font-weight: 900;      color: #ff6b9d;      text-shadow: 0 0 20px rgba(255, 107, 157, 0.5);      margin: 10px 0;    }    .content-section {      flex: 1;      padding: 40px 20px;      max-width: 1000px;      margin: 0 auto;      width: 100%;    }    .game-container {      background: rgba(20, 20, 40, 0.7);      border: 2px solid rgba(200, 100, 150, 0.4);      border-radius: 12px;      padding: 40px;      backdrop-filter: blur(10px);      box-shadow:         0 0 40px rgba(200, 100, 150, 0.15),        inset 0 0 30px rgba(139, 69, 19, 0.1);      animation: fadeInUp 0.8s ease-out;    }    @keyframes fadeInUp {      from {        opacity: 0;        transform: translateY(30px);      }      to {        opacity: 1;        transform: translateY(0);      }    }    .welcome-screen {      text-align: center;    }    .welcome-text {      font-size: 1.3rem;      color: #d0a0d0;      margin-bottom: 30px;      line-height: 1.6;    }    .play-button {      background: linear-gradient(135deg, #ff6b9d 0%, #c44569 100%);      border: none;      color: white;      padding: 16px 50px;      font-size: 1.2rem;      font-family: 'Cinzel', serif;      border-radius: 8px;      cursor: pointer;      transition: all 0.3s ease;      text-transform: uppercase;      letter-spacing: 2px;      box-shadow: 0 0 30px rgba(255, 107, 157, 0.4);      margin-top: 20px;    }    .play-button:hover {      transform: translateY(-3px);      box-shadow: 0 0 50px rgba(255, 107, 157, 0.6);    }    .play-button:active {      transform: translateY(0);    }    .quiz-screen {      display: none;    }    .quiz-screen.active {      display: block;      animation: fadeInUp 0.6s ease-out;    }    .progress-bar {      background: rgba(100, 100, 120, 0.4);      height: 8px;      border-radius: 4px;      margin-bottom: 30px;      overflow: hidden;      border: 1px solid rgba(200, 100, 150, 0.3);    }    .progress-fill {      background: linear-gradient(90deg, #ff6b9d 0%, #c44569 100%);      height: 100%;      transition: width 0.4s ease;      box-shadow: 0 0 15px rgba(255, 107, 157, 0.6);    }    .question-number {      font-size: 0.9rem;      color: #b8a0d0;      margin-bottom: 15px;      text-transform: uppercase;      letter-spacing: 1px;    }    .question-text {      font-size: 1.6rem;      font-family: 'Cinzel', serif;      margin-bottom: 30px;      color: #e0d0ff;      line-height: 1.5;    }    .answers-grid {      display: grid;      grid-template-columns: 1fr 1fr;      gap: 15px;      margin-bottom: 30px;    }    .answer-button {      background: rgba(80, 60, 100, 0.5);      border: 2px solid rgba(200, 100, 150, 0.4);      color: #e0e0e0;      padding: 20px;      border-radius: 8px;      cursor: pointer;      transition: all 0.3s ease;      font-size: 1rem;      font-family: 'Outfit', sans-serif;      text-align: center;      line-height: 1.4;    }    .answer-button:hover {      background: rgba(200, 100, 150, 0.3);      border-color: rgba(200, 100, 150, 0.7);      transform: translateY(-2px);      box-shadow: 0 0 20px rgba(200, 100, 150, 0.3);    }    .answer-button.correct {      background: rgba(100, 200, 100, 0.4);      border-color: #64c864;      color: #90ff90;      box-shadow: 0 0 30px rgba(100, 200, 100, 0.5);    }    .answer-button.incorrect {      background: rgba(200, 100, 100, 0.4);      border-color: #c86464;      color: #ff9090;      box-shadow: 0 0 30px rgba(200, 100, 100, 0.5);    }    .answer-button:disabled {      cursor: not-allowed;    }    .results-screen {      display: none;      text-align: center;    }    .results-screen.active {      display: block;      animation: fadeInUp 0.6s ease-out;    }    .score-display {      font-family: 'Cinzel', serif;      font-size: 5rem;      font-weight: 900;      color: #ff6b9d;      margin: 30px 0;      text-shadow: 0 0 30px rgba(255, 107, 157, 0.5);    }    .results-text {      font-size: 1.3rem;      color: #d0a0d0;      margin-bottom: 40px;      line-height: 1.6;    }    .restart-button {      background: linear-gradient(135deg, #c44569 0%, #ff6b9d 100%);      border: none;      color: white;      padding: 14px 40px;      font-size: 1rem;      font-family: 'Cinzel', serif;      border-radius: 8px;      cursor: pointer;      transition: all 0.3s ease;      text-transform: uppercase;      letter-spacing: 2px;      box-shadow: 0 0 30px rgba(255, 107, 157, 0.4);    }    .restart-button:hover {      transform: translateY(-3px);      box-shadow: 0 0 50px rgba(255, 107, 157, 0.6);    }    .emoji-celebration {      font-size: 4rem;      margin: 20px 0;      animation: float 2s ease-in-out infinite;    }    @keyframes float {      0%, 100% { transform: translateY(0); }      50% { transform: translateY(-20px); }    }    .victory-screen {      display: none;      text-align: center;      animation: fadeInUp 0.6s ease-out;    }    .victory-screen.active {      display: block;    }    .victory-title {      font-family: 'Cinzel', serif;      font-size: 4.5rem;      font-weight: 900;      text-transform: uppercase;      letter-spacing: 4px;      margin-bottom: 30px;      color: #ff6b9d;      text-shadow: 0 0 40px rgba(255, 107, 157, 0.6);      animation: pulse 1.5s ease-in-out infinite;    }    @keyframes pulse {      0%, 100% {         text-shadow: 0 0 40px rgba(255, 107, 157, 0.6);        transform: scale(1);      }      50% {         text-shadow: 0 0 60px rgba(255, 107, 157, 0.8);        transform: scale(1.05);      }    }    .victory-message {      font-size: 1.5rem;      color: #d0a0d0;      margin-bottom: 40px;      line-height: 1.8;      font-weight: 300;    }    .victory-emojis {      font-size: 5rem;      margin: 30px 0;      animation: float 2s ease-in-out infinite;    }    .near-victory-message {      font-size: 1.4rem;      color: #d0a0d0;      margin-bottom: 40px;      line-height: 1.8;      font-style: italic;    }    @media (max-width: 640px) {      .title-main {        font-size: 2.5rem;      }      .age-badge {        font-size: 3rem;      }      .game-container {        padding: 25px;      }      .question-text {        font-size: 1.3rem;      }      .answers-grid {        grid-template-columns: 1fr;      }    }
.keys-area{
  display:flex;
  justify-content:center;
  gap:40px;
  margin:30px 0;
}

.key{
  font-size:70px;
  cursor:pointer;
}

.key.collected{
  opacity:0.2;
}
#prizeScreen{
  text-align:center;
  max-width:800px;
  margin:auto;
}

#prizeScreen .victory-message{
  font-size:1.4rem;
  line-height:2;
  color:#f4d4ff;
  margin-top:30px;
}
